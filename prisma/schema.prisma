generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                String             @id @default(uuid())
  email             String             @unique
  password          String?
  provider          Provider?
  isActivated       Boolean            @default(false) @map("is_activated")
  createdAt         DateTime           @default(now()) @map("created_at")
  updatedAt         DateTime           @updatedAt @map("updated_at")
  username          String             @unique
  activationCode    ActivationCode?
  decks             Deck[]
  deckCategories    DeckCategory[]
  profile           Profile?
  resetPasswordCode ResetPasswordCode?
  tokens            Token[]

  @@map("user")
}

model Profile {
  id         String   @id @default(uuid())
  avatarPath String   @default("avatar/defaultAvatar.jpg") @map("avatar_path")
  firstName  String   @default("") @map("first_name")
  lastName   String   @default("") @map("last_name")
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId     String   @unique @map("user_id")
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")

  @@map("profile")
}

model ActivationCode {
  code      Int
  userId    String   @unique @map("user_id")
  expiresAt DateTime @default(now()) @map("expires_at")
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("activation_code")
}

model ResetPasswordCode {
  code      Int
  attempts  Int      @default(0)
  expiresAt DateTime @map("expires_at")
  userId    String   @unique @map("user_id")
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("reset_password_code")
}

model Token {
  token     String   @unique
  exp       DateTime
  userId    String   @map("user_id")
  userAgent String   @map("user_agent")
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("token")
}

model Deck {
  id             String       @id @default(uuid())
  name           String
  description    String?
  cardCount      Int          @default(0) @map("card_count")
  deckCategoryId String       @map("deck_category_id")
  userId         String       @map("user_id")
  createdAt      DateTime     @default(now()) @map("created_at")
  updatedAt      DateTime     @updatedAt @map("updated_at")
  cards          Card[]
  deckCategory   DeckCategory @relation(fields: [deckCategoryId], references: [id], onDelete: Cascade)
  user           User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  deckSession    DeckSession?

  @@index([updatedAt, id])
  @@index([createdAt, id])
  @@index([cardCount, id])
  @@index([name, id])
  @@index([deckCategoryId])
  @@map("deck")
}

model DeckCategory {
  id          String       @id @default(uuid())
  name        String
  createdAt   DateTime     @default(now()) @map("created_at")
  updatedAt   DateTime     @updatedAt @map("updated_at")
  userId      String       @map("user_id")
  icon        String       @default("bookOpen")
  color       String       @default("blue")
  fsrsWeights FSRSWeights?
  deck        Deck[]
  user        User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, name])
  @@map("deck_category")
}

model FSRSWeights {
  id         String       @id @default(uuid())
  w          Json         @default("[0.212, 1.2931, 2.3065, 8.2956, 6.4133, 0.8334, 3.0194, 0.001, 1.8722, 0.1666, 0.796, 1.4835, 0.0614, 0.2629, 1.6483, 0.6014, 1.8729]")
  updatedAt  DateTime     @updatedAt @map("updated_at")
  categoryId String       @unique @map("category_id")
  category   DeckCategory @relation(fields: [categoryId], references: [id], onDelete: Cascade)

  @@map("FSRS_weights")
}

model DeckSession {
  id              String   @id @default(uuid())
  mastery         Int      @default(0)
  totalTime       Int      @default(0)
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")
  deckId          String   @unique @map("deck_id")
  isShortTerm     Boolean  @default(false) @map("is_short_term")
  cardsPerSession Int      @default(10) @map("cards_per_session")
  deck            Deck     @relation(fields: [deckId], references: [id], onDelete: Cascade)

  @@index([mastery, deckId])
  @@index([updatedAt, deckId])
  @@map("deck_session")
}

model Card {
  id            String    @id @default(uuid())
  question      String
  answer        String
  createdAt     DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime  @updatedAt @map("updated_at")
  deckId        String    @map("deck_id")
  plainAnswer   String
  plainQuestion String
  fsrsCard      FSRSCard?
  deck          Deck      @relation(fields: [deckId], references: [id], onDelete: Cascade)

  @@index([createdAt, id])
  @@index([deckId])
  @@map("card")
}

model FSRSCard {
  id             String        @id @default(uuid())
  due            DateTime
  stability      Float
  difficulty     Float
  elapsed_days   Int
  scheduled_days Int
  learning_steps Int
  reps           Int
  lapses         Int
  state          Int
  last_review    DateTime?
  cardId         String        @unique @map("card_id")
  card           Card          @relation(fields: [cardId], references: [id], onDelete: Cascade)
  logs           FSRSCardLog[]

  @@index([difficulty, id])
  @@index([cardId])
  @@index([due])
  @@index([difficulty, stability, due])
  @@map("FSRS_card")
}

model FSRSCardLog {
  id                String   @id @default(uuid())
  review            DateTime
  rating            Int
  state             Int
  due               DateTime
  stability         Float
  difficulty        Float
  elapsed_days      Int
  last_elapsed_days Int
  scheduled_days    Int
  learning_steps    Int
  fsrsCardId        String   @map("fsrs_card_id")
  fsrsCard          FSRSCard @relation(fields: [fsrsCardId], references: [id], onDelete: Cascade)

  @@index([fsrsCardId])
  @@index([review])
  @@index([fsrsCardId, review])
  @@map("FSRS_card_log")
}

enum Provider {
  GOOGLE
}
